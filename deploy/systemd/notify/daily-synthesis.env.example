# daily-synthesis.env — per-slug config for isidore-cloud-notify@daily-synthesis
# Install: sudo cp daily-synthesis.env.example /etc/isidore-cloud/notify/daily-synthesis.env
#
# Replaces bridge scheduler "daily-synthesis" job (cron 0 2 * * *, type=synthesis).
# Original emitted a pipeline task; systemd version runs the prompt directly
# and sends the text result via notify.sh.
#
# Prereq: claude CLI must be authenticated as isidore_cloud user.
#   sudo -u isidore_cloud claude auth status
NOTIFY_CMD='claude -p "Run memory synthesis: review recent episodes, distill knowledge, identify patterns." --output-format text'
