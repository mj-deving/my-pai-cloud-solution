# daily-memory.env — per-slug config for isidore-cloud-notify@daily-memory
# Install: sudo cp daily-memory.env.example /etc/isidore-cloud/notify/daily-memory.env
#
# Replaces bridge scheduler "daily-memory" job (cron 55 22 * * *, type=daily-memory).
NOTIFY_CMD='claude -p "Write daily memory summary" --output-format text'
