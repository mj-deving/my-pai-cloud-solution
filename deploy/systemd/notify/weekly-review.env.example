# weekly-review.env — per-slug config for isidore-cloud-notify@weekly-review
# Install: sudo cp weekly-review.env.example /etc/isidore-cloud/notify/weekly-review.env
#
# Replaces bridge scheduler "weekly-review" job (cron 0 3 * * 0, type=task).
NOTIFY_CMD='claude -p "System health review: check memory stats, pipeline throughput, error rates, disk usage. Report anomalies." --output-format text'
