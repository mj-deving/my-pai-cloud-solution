# daily-memory.conf — drop-in override for isidore-cloud-notify@daily-memory.timer
# Install:
#   sudo mkdir -p /etc/systemd/system/isidore-cloud-notify@daily-memory.timer.d
#   sudo cp daily-memory.conf.example \
#     /etc/systemd/system/isidore-cloud-notify@daily-memory.timer.d/override.conf
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now isidore-cloud-notify@daily-memory.timer
#
# Matches bridge cron "55 22 * * *" (22:55 UTC daily).

[Timer]
OnCalendar=
OnCalendar=*-*-* 22:55:00 UTC
