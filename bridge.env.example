# Isidore Cloud Bridge — Environment Configuration
# Copy to /home/isidore_cloud/.config/isidore_cloud/bridge.env on VPS

# Telegram (required)
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_ALLOWED_USER_ID=your-telegram-user-id

# Session management
SESSION_ID_FILE=/home/isidore_cloud/.claude/active-session-id
CLAUDE_BINARY=/home/isidore_cloud/.npm-global/bin/claude

# Project handoff
PROJECT_REGISTRY_FILE=/home/isidore_cloud/pai-knowledge/HANDOFF/projects.json
HANDOFF_STATE_FILE=/home/isidore_cloud/.claude/handoff-state.json
PROJECT_SYNC_SCRIPT=/home/isidore_cloud/projects/my-pai-cloud-solution/scripts/project-sync.sh
KNOWLEDGE_SYNC_SCRIPT=/home/isidore_cloud/projects/my-pai-cloud-solution/scripts/sync-knowledge.sh

# Email (optional — Phase 4)
# EMAIL_IMAP_HOST=imap.example.com
# EMAIL_IMAP_PORT=993
# EMAIL_IMAP_USER=isidore@example.com
# EMAIL_IMAP_PASS=your-email-password
# EMAIL_SMTP_HOST=smtp.example.com
# EMAIL_SMTP_PORT=587
# EMAIL_FROM_ADDRESS=isidore@example.com
# EMAIL_ALLOWED_SENDERS=marius@example.com,marius@other.com
