# Isidore Bridge — Environment Configuration
# Copy to /home/isidore/.config/isidore/bridge.env on VPS

# Telegram (required)
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_ALLOWED_USER_ID=your-telegram-user-id

# Session management
SESSION_ID_FILE=/home/isidore/.claude/active-session-id
CLAUDE_BINARY=/home/isidore/.npm-global/bin/claude

# Email (optional — Phase 4)
# EMAIL_IMAP_HOST=imap.example.com
# EMAIL_IMAP_PORT=993
# EMAIL_IMAP_USER=isidore@example.com
# EMAIL_IMAP_PASS=your-email-password
# EMAIL_SMTP_HOST=smtp.example.com
# EMAIL_SMTP_PORT=587
# EMAIL_FROM_ADDRESS=isidore@example.com
# EMAIL_ALLOWED_SENDERS=marius@example.com,marius@other.com
